{
  "version": 2,
  "builds": [
    {
      "src": "api/server.mjs",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "public/swagger-ui/**",
          "docs/**"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/api/server.mjs"
    }
  ]
}
